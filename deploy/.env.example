# Copy this file to ".env" (same folder) and fill in the blanks.
# Never commit the real .env — it holds secrets.

# ---- Database ----
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me
POSTGRES_DB=atlas

# ---- App ----
# Host port the app is published on (container always listens on 8080).
ATLAS_PORT=8080

# Connection string the app uses to reach the db service (host is "db").
# Keep the password in sync with POSTGRES_PASSWORD above. Avoid '$' in it.
ATLAS_DATABASE_URL=postgres://atlas:change-me@db:5432/atlas?sslmode=disable

# Random signing secret for sessions. Generate one with:
#   openssl rand -hex 32
ATLAS_SESSION_SECRET=

# Editor login name. The PASSWORD HASH is NOT set here — it goes into the file
# deploy/editor_hash.txt (mounted as a Docker secret), because a bcrypt hash
# contains '$' which docker-compose would otherwise mangle. Create it with:
#   docker compose run --rm --no-deps app hashpw 'your-password' > editor_hash.txt
ATLAS_EDITOR_USERNAME=editor
